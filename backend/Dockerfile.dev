# Dockerfile para desarrollo con hot reload
FROM node:20-alpine

WORKDIR /app

# Install build dependencies for native modules (sqlite3, bcrypt, etc.)
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install ALL dependencies (incluyendo devDependencies)
RUN npm install

# Copy application code
COPY . .

# Expose backend port
EXPOSE 5000

# Run in development mode with nodemon
CMD ["npm", "run", "dev"]
